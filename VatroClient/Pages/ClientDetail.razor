@page "/client/{Id:int}"
@inject HttpClient Http

<PageTitle>Klijent titile</PageTitle>

<h1>Klijent header</h1>

@if (Client == null) {
    <div>Loading...</div>
} else {
    <div class="">
        <div class="flex">
            <div class="mr-2">Naziv:</div>
            <div class="text-bold">@Client.Name</div>
        </div>
        <div class="flex">
            <div class="mr-2">Mesto:</div>
            <div class="text-bold">@Client.City</div>
        </div>
    </div>
}

@* <p role="status">Current count: @currentCount</p> *@

@* <button class="btn btn-primary" @onclick="IncrementCount">Click me</button> *@

@code {
    @using VatroClient.Models

    [Parameter]
    public int Id { get; set; }

    private Client? Client;

    protected override async Task OnInitializedAsync()
    {
        Client = await Http.GetFromJsonAsync<Client>("/api/client/" + Id);
    }
}
